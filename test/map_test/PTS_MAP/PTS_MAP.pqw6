      <PIXIT>
        <Name>MAP</Name>
        <Version />
        <Rows>
          <Row>
            <Name>TSPX_auth_password</Name>
            <Description>Password used during the AUTHENTICATION digest resposne. (Default: "0000")</Description>
            <Type>IA5STRING</Type>
            <Value>0000</Value>
          </Row>
          <Row>
            <Name>TSPX_auth_user_id</Name>
            <Description>User ID used during the AUTEHNTICATION digest response.  (Default: "PTS")</Description>
            <Type>IA5STRING</Type>
            <Value>PTS</Value>
          </Row>
          <Row>
            <Name>TSPX_bd_addr_iut</Name>
            <Description>The unique 48-bit Bluetooth device address (BD_ADDR) of the IUT. This was filled in during workspace creation.</Description>
            <Type>OCTETSTRING</Type>
            <Value>5CF370607B87</Value>
          </Row>
          <Row>
            <Name>TSPX_client_class_of_device</Name>
            <Description>The indicated capabilities of PTS in CLIENT role (Default: 100204)</Description>
            <Type>OCTETSTRING</Type>
            <Value>100204</Value>
          </Row>
          <Row>
            <Name>TSPX_delete_link_key</Name>
            <Description>Whether to delete the stored link key in PTS at the beginning of each test case. (Default: FALSE)</Description>
            <Type>BOOLEAN</Type>
            <Value>FALSE</Value>
          </Row>
          <Row>
            <Name>TSPX_initial_path</Name>
            <Description>If not empty, PTS will send a SET_PATH before doing a PUT or GET. (Default: "")</Description>
            <Type>IA5STRING</Type>
            <Value />
          </Row>
          <Row>
            <Name>TSPX_l2cap_psm</Name>
            <Description>The PSM PTS advertises in its SDP record if GOEP 2.0 is being tested.  This value should be in hexadecimal format, but should not include a leading 0x. (Default: 1001)</Description>
            <Type>OCTETSTRING</Type>
            <Value>1001</Value>
          </Row>
          <Row>
            <Name>TSPX_no_confirmations</Name>
            <Description>Must be set to FALSE for qualification.  Setting to TRUE will disable requests for the user to confirm the PUT and GET commands, but will not be usable for qualification test results.  (Default: FALSE)</Description>
            <Type>BOOLEAN</Type>
            <Value>FALSE</Value>
          </Row>
          <Row>
            <Name>TSPX_pin_code</Name>
            <Description>The PIN code that is used to authenticate connections between PTS and IUT. (Default: 0000)</Description>
            <Type>IA5STRING</Type>
            <Value>0000</Value>
          </Row>
          <Row>
            <Name>TSPX_rfcomm_channel</Name>
            <Description>RFCOMM server channel that will be opened for incoming OBEX connections from the IUT for OBEX. (Default: 8)</Description>
            <Type>INTEGER</Type>
            <Value>8</Value>
          </Row>
          <Row>
            <Name>TSPX_secure_simple_pairing_pass_key_confirmation</Name>
            <Description>Whether manual confirmation on generated key is required during secure simple pairing (Default: FALSE)</Description>
            <Type>BOOLEAN</Type>
            <Value>FALSE</Value>
          </Row>
          <Row>
            <Name>TSPX_security_enabled</Name>
            <Description>Whether security is required for establishing connections. (Default: FALSE)</Description>
            <Type>BOOLEAN</Type>
            <Value>TRUE</Value>
          </Row>
          <Row>
            <Name>TSPX_server_class_of_device</Name>
            <Description>The indicated capabilities of PTS in SERVER role (Default: 100204)</Description>
            <Type>OCTETSTRING</Type>
            <Value>100204</Value>
          </Row>
          <Row>
            <Name>TSPX_time_guard</Name>
            <Description>The time in milliseconds, to break PTS from waiting for a required event, if time guard is used by the test case. (Default: 300000)</Description>
            <Type>INTEGER</Type>
            <Value>300000</Value>
          </Row>
          <Row>
            <Name>TSPX_use_implicit_send</Name>
            <Description>Whether to receive a message via Implicit Send when an action or attention is needed by test operator. (Default: TRUE)</Description>
            <Type>BOOLEAN</Type>
            <Value>TRUE</Value>
          </Row>
          <Row>
            <Name>TSPX_SPP_rfcomm_channel</Name>
            <Description>The RFCOMM server channel to be used in the PTS for SPP. (Default: 03)</Description>
            <Type>OCTETSTRING</Type>
            <Value>03</Value>
          </Row>
          <Row>
            <Name>TSPX_filter_period_begin</Name>
            <Description>Parameter in "YYYYMMDDTHHMMSS" to filter with if IUT supports FilterPeriodBegin. (Default: 20100101T000000)</Description>
            <Type>IA5STRING</Type>
            <Value>20100101T000000</Value>
          </Row>
          <Row>
            <Name>TSPX_filter_period_end</Name>
            <Description>Parameter in "YYYYMMDDTHHMMSS" to filter with if IUT supports FilterPeriodEnd. (Default: 20111231T125959)</Description>
            <Type>IA5STRING</Type>
            <Value>20111231T125959</Value>
          </Row>
          <Row>
            <Name>TSPX_filter_recipient</Name>
            <Description>Name of recipient to filter with if IUT supports FilterRecipient. (Default: IUT)</Description>
            <Type>IA5STRING</Type>
            <Value>IUT</Value>
          </Row>
          <Row>
            <Name>TSPX_filter_originator</Name>
            <Description>Name of originator to filter with if IUT supports FilterOriginator. (Default: PTS)</Description>
            <Type>IA5STRING</Type>
            <Value>PTS</Value>
          </Row>
          <Row>
            <Name>TSPX_filter_last_activity_begin</Name>
            <Description>Parameter in "YYYYMMDDTHHMMSS" to filter with if IUT supports FilterPeriodBegin. (Default: 20100101T000000)</Description>
            <Type>IA5STRING</Type>
            <Value>20100101T000000</Value>
          </Row>
          <Row>
            <Name>TSPX_filter_last_activity_end</Name>
            <Description>Parameter in "YYYYMMDDTHHMMSS" to filter with if IUT supports FilterPeriodEnd. (Default: 20111231T125959)</Description>
            <Type>IA5STRING</Type>
            <Value>20111231T125959</Value>
          </Row>
          <Row>
            <Name>TSPX_default_message_upload_folder_in_msg</Name>
            <Description>Name of the default folder on the MSE where a message will be uploaded to. (Default: draft)</Description>
            <Type>IA5STRING</Type>
            <Value>draft</Value>
          </Row>
          <Row>
            <Name>TSPX_default_test_folder_in_msg</Name>
            <Description>Name of the default folder on the MSE where messages will be used for testing if particular folder is not specified in the test case. (Default: inbox)</Description>
            <Type>IA5STRING</Type>
            <Value>inbox</Value>
          </Row>
          <Row>
            <Name>TSPX_message_notification_l2cap_psm</Name>
            <Description>The PSM PTS advertises in its SDP record if GOEP 2.0 is being tested.  This value should be in hexadecimal format, but should not include a leading 0x. (Default: 1005)</Description>
            <Type>OCTETSTRING</Type>
            <Value>1005</Value>
          </Row>
          <Row>
            <Name>TSPX_message_notification_rfcomm_channel</Name>
            <Description>RFCOMM server channel that will be opened for incoming OBEX connections from the IUT for OBEX. (Default: 10)</Description>
            <Type>INTEGER</Type>
            <Value>10</Value>
          </Row>
          <Row>
            <Name>TSPX_upload_msg_phonenumber</Name>
            <Description>Name of the phone number on the MSE where a message will be used for sending to network. (Default: 0000000)</Description>
            <Type>IA5STRING</Type>
            <Value>0000000</Value>
          </Row>
          <Row>
            <Name>TSPX_upload_msg_emailaddress</Name>
            <Description>Name of the email address on the MSE where a message will be used for sending to network. (Default: Iut_emailaddress)</Description>
            <Type>IA5STRING</Type>
            <Value>Iut_emailaddress</Value>
          </Row>
          <Row>
            <Name>TSPX_Automation</Name>
            <Description>Automation state. (Default: FALSE)</Description>
            <Type>BOOLEAN</Type>
            <Value>FALSE</Value>
          </Row>
        </Rows>
      </PIXIT>
    </PROJECT_INFORMATION>
  </PROJECTS_INFORMATION>
</WORKSPACE_INFORMATION>